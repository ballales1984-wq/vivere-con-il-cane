# Environment variables for Vivere con il Cane

# =============================================
# GOOGLE OAUTH 2.0 CREDENTIALS
# =============================================
# Configura in Google Cloud Console:
# 1. Vai su https://console.cloud.google.com/
# 2. Crea progetto → Abilita "Google Fit API"
# 3. APIs & Services → Credentials → CREATE → OAuth client ID (Web application)
# 4. Aggiungi redirect URIs (vedi guida completa)
# 5. Copia Client ID e Client Secret qui sotto

# Per Social Login (allauth) + Health/Fit Sync
# Leggi GOOGLE_OAUTH_COMPLETE_GUIDE.md per istruzioni dettagliate
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your_client_secret_here
# (Opzionale) Override redirect URI - lascia vuoto per default in settings.py
# Sviluppo locale: http://localhost:8000/auth/google/callback
# Produzione: https://vivere-con-il-cane.onrender.com/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=

# =============================================
# GROK API (xAI) - Per analisi AI cardiache
# =============================================
# Get your key at https://console.x.ai
GROK_API_KEY=your_grok_key_here

# OpenAI API (opzionale, fallback se Grok non disponibile)
OPENAI_API_KEY=your_openai_key_here

# =============================================
# EMAIL CONFIGURATION (SMTP)
# =============================================
# Per sviluppo: usa console backend (stampa email su stdout)
# Per produzione: usa SMTP reale (Gmail, Sendgrid, Mailgun, etc.)

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tuoemail@gmail.com
EMAIL_HOST_PASSWORD=la-tua-app-password-gmail
DEFAULT_FROM_EMAIL=tuoemail@gmail.com
SERVER_EMAIL=noreply@tuodominio.com

# =============================================
# DATABASE (solo per produzione es. Render)
# =============================================
# Se usi PostgreSQL, Render fornisce DATABASE_URL automaticamente
# Altrimenti configura manualmente:
DB_NAME=vivere_con_cane
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# =============================================
# OTHER SETTINGS (opzionali)
# =============================================
# Debug mode (True/False) - in produzione metti False
DEBUG=True

# Secret key Django (generata automaticamente in produzione)
SECRET_KEY=your-secret-key-here-min-50-chars-change-in-production
